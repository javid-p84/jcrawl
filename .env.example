# jcrawl Configuration

# Database
DATABASE_URL=postgres://user:password@localhost:5432/jcrawl?sslmode=disable

# Server
SERVER_PORT=8080
SERVER_ENV=development

# Worker
WORKER_CHECK_INTERVAL_MINUTES=5

# Browser/Scraper (requires Chrome/Chromium installed)
# Set to false if you don't want to run browser automation
ENABLE_SCRAPER=true
SCRAPER_TIMEOUT_SECONDS=30

# JWT (for authentication)
JWT_SECRET=your-secret-key-here

# Logging
LOG_LEVEL=info
