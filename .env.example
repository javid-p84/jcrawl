# jcrawl Configuration

# Restaurant Booking Preferences
RESTAURANT_GOOGLE_LINK=https://www.google.com/maps/place/...
RESTAURANT_PARTY_SIZE=2

# Date Range (YYYY-MM-DD)
DATE_RANGE_FROM=2024-01-01
DATE_RANGE_TO=2024-01-31

# Day Preferences (comma-separated, 0=Sunday, 6=Saturday)
DAY_PREFERENCE=5,6

# Check interval (in minutes)
CHECK_INTERVAL_MINUTES=5

# Auto-booking (true/false)
AUTO_BOOK=true

# Logging
LOG_LEVEL=info
